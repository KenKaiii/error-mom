# PostgreSQL connection string.
# Local: matches docker-compose.yml. Railway: use ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/error_mom

# Optional. "disable" skips TLS. Auto-disabled for localhost and Railway private networking.
DATABASE_SSL=disable

# Private admin token for dashboards and coding agents. Minimum 32 characters.
# Generate with: openssl rand -hex 32
ERROR_MOM_ADMIN_TOKEN=replace-with-at-least-32-random-characters

# Public base URL of this deployment (used by SDK setup snippets).
NEXT_PUBLIC_ERROR_MOM_URL=http://localhost:3000

# Optional. Run the PostgreSQL integration test suite against this database.
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/error_mom_test
