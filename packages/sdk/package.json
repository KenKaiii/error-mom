{
  "name": "@kenkaiiii/error-mom",
  "version": "0.3.5",
  "description": "Automatic browser and Node.js error capture for self-hosted Error Mom",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node.ts --format esm,cjs --dts --clean",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kenkaiiii/error-mom-protocol": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "module": "./dist/index.js"
}
