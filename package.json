{
  "name": "error-mom-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm --filter @kenkaiiii/error-mom-protocol build && pnpm -r check",
    "dev": "pnpm --filter error-mom-web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter error-mom-web db:migrate",
    "db:seed": "pnpm --filter error-mom-web db:seed"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prettier": "^3.8.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.9.3",
      "postcss": ">=8.5.10",
      "esbuild": ">=0.28.1"
    }
  }
}
